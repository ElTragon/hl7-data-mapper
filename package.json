{
  "name": "hl7-data-mapper",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.13.1 <23"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm --filter contracts build && pnpm --filter hl7-parser build && pnpm --filter mapping-engine build && pnpm --filter report-generator build && pnpm --filter api typecheck && pnpm --filter web typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "deploy:api": "pnpm --filter api deploy",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.9.4"
  }
}
