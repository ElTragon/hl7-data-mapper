{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hl7-data-mapper-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-09",
  "observability": {
    "enabled": true,
  },
  "vars": {
    "DEMO_DATA_POLICY": "synthetic-only",
    "REPORT_MAX_BYTES": "5242880",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "hl7-data-mapper-demo",
      "database_id": "replace-with-cloudflare-d1-database-id",
    },
  ],
}
